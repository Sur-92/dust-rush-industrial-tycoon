[gd_resource type="Resource" script_class="MachineDefinition" load_steps=3 format=3]

[ext_resource type="Script" path="res://data/machine_definition.gd" id="1_definition"]
[ext_resource type="Script" path="res://data/engineering_source.gd" id="2_source"]

[sub_resource type="Resource" id="Resource_source"]
script = ExtResource("2_source")
classification = 0
basis = "Grizzly specifies at least 600 CFM through a 5-inch port for representative 20-inch planers."
url = "https://support.grizzly.com/hc/en-us/articles/35556746739095-FAQ-G0454Z-G0454ZX-20-Planers"
accessed = "2026-07-22"

[resource]
script = ExtResource("1_definition")
machine_id = &"planer"
display_name = "Planer"
collection_demand = 3
description = "High-volume chips when stock is being surfaced."
airflow_cfm = 600
pickup_count = 1
pickup_diameter_inches = 5.0
branch_diameter_inches = 5.0
airflow_source = SubResource("Resource_source")
