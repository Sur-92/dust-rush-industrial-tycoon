[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/main.gd" id="1_main"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_main")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.031, 0.047, 0.071, 1)
mouse_filter = 2

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 72
theme_override_constants/margin_top = 56
theme_override_constants/margin_right = 72
theme_override_constants/margin_bottom = 56

[node name="Content" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="Eyebrow" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.957, 0.659, 0.267, 1)
theme_override_font_sizes/font_size = 18
text = "TEN-MINUTE INDUSTRIAL SPRINT"

[node name="Title" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.953, 0.969, 0.984, 1)
theme_override_font_sizes/font_size = 46
text = "DUST RUSH"

[node name="Subtitle" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.69, 0.749, 0.82, 1)
theme_override_font_sizes/font_size = 22
text = "Solve the job. Clear the air. Beat the clock."

[node name="Spacer" type="Control" parent="Margin/Content"]
custom_minimum_size = Vector2(0, 72)
layout_mode = 2

[node name="TimerLabel" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.953, 0.969, 0.984, 1)
theme_override_font_sizes/font_size = 88
text = "10:00"

[node name="StatusLabel" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.588, 0.827, 0.722, 1)
theme_override_font_sizes/font_size = 20
text = "Scaffold running — first customer is the next ticket."

[node name="Controls" type="HBoxContainer" parent="Margin/Content"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="PauseButton" type="Button" parent="Margin/Content/Controls"]
custom_minimum_size = Vector2(150, 48)
layout_mode = 2
text = "Pause"

[node name="RestartButton" type="Button" parent="Margin/Content/Controls"]
custom_minimum_size = Vector2(150, 48)
layout_mode = 2
text = "Restart"

[connection signal="pressed" from="Margin/Content/Controls/PauseButton" to="." method="_on_pause_pressed"]
[connection signal="pressed" from="Margin/Content/Controls/RestartButton" to="." method="_on_restart_pressed"]
